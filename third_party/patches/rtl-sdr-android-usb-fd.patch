+#if defined(__ANDROID__)
+static int urchin_android_wrapped_fd(void)
+{
+	const char *fd_env = getenv("URCHIN_RTLSDR_FD");
+	char *end = NULL;
+	long fd;
+
+	if (!fd_env || !*fd_env)
+		return -1;
+
+	fd = strtol(fd_env, &end, 10);
+	if (!end || *end != '\0' || fd < 0 || fd > INT_MAX)
+		return -1;
+
+	return (int)fd;
+}
+#endif
