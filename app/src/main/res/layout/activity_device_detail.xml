<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/urchin_background"
  android:orientation="vertical">

  <com.google.android.material.appbar.MaterialToolbar
    android:id="@+id/toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/urchin_surface"
    android:elevation="0dp"
    android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
    android:title="@string/device_details"
    app:navigationIconTint="@color/urchin_secondary"
    app:titleTextColor="@color/urchin_on_surface" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/urchin_stroke_soft" />

  <ScrollView
    android:id="@+id/detailScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:id="@+id/detailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/urchin_secondary"
        android:textSize="22sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/detailIdentity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/urchin_on_background" />

      <TextView
        android:id="@+id/detailKey"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/urchin_on_background" />

      <TextView
        android:id="@+id/detailFirstSeen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/urchin_on_background" />

      <TextView
        android:id="@+id/detailLastSeen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/urchin_on_background" />

      <TextView
        android:id="@+id/detailStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/urchin_on_background" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/latest_reading"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/detailReading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_surface_subtle"
        android:padding="16dp"
        android:textColor="@color/urchin_on_surface"
        android:textIsSelectable="true" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/raw_json"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/detailMetadata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_surface_subtle"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:textColor="@color/urchin_on_surface"
        android:textIsSelectable="true" />

      <TextView
        android:id="@+id/relatedEmittersLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/related_emitters"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold"
        android:visibility="gone" />

      <TextView
        android:id="@+id/relatedEmittersList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_surface_subtle"
        android:padding="16dp"
        android:textColor="@color/urchin_on_surface"
        android:visibility="gone" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/sightings"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sightingsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false"
        android:paddingBottom="16dp" />
    </LinearLayout>
  </ScrollView>
</LinearLayout>
