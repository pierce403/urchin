<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginHorizontal="16dp"
  android:layout_marginTop="8dp"
  android:layout_marginBottom="8dp"
  app:cardBackgroundColor="@color/urchin_surface_variant"
  app:cardCornerRadius="20dp"
  app:cardElevation="0dp"
  app:strokeColor="@color/urchin_stroke_soft"
  app:strokeWidth="1dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/ruleEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp" />

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/ruleTitle"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="@color/urchin_secondary"
          android:textStyle="bold"
          android:textSize="16sp" />

        <TextView
          android:id="@+id/ruleMeta"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:textColor="@color/urchin_on_background" />
      </LinearLayout>

      <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/ruleEnabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:orientation="horizontal">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/editRuleButton"
        style="@style/UrchinSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit_alert" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/deleteRuleButton"
        style="@style/UrchinSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/delete_alert" />
    </LinearLayout>
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>
