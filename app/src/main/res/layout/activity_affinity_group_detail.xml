<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Group info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_info"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:id="@+id/groupDetailInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sharing config -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sharing_config"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/shareDevices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/share_devices" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/shareSightings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/share_sightings" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/shareAlertRules"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/share_alert_rules" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/shareStarred"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/share_starred" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/shareTpms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/share_tpms" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Members -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/group_members"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/membersList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/exportBundleButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/export_bundle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shareGroupKeyButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/share_group_key" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteGroupButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/delete_group"
                android:textColor="?attr/colorError" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
