<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/drawerLayout"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/urchin_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/urchin_surface"
      android:elevation="0dp"
      android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
      android:title="@string/app_name_header"
      app:navigationIconTint="@color/urchin_secondary"
      app:subtitleTextColor="@color/urchin_secondary"
      app:titleTextColor="@color/urchin_on_surface" />

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/urchin_stroke_soft" />

    <HorizontalScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@color/urchin_surface"
      android:paddingStart="12dp"
      android:paddingEnd="12dp"
      android:paddingTop="6dp"
      android:paddingBottom="6dp"
      android:scrollbars="none">

      <com.google.android.material.chip.ChipGroup
        android:id="@+id/protocolChips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleLine="true"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
          android:id="@+id/chipAll"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:checked="true"
          android:text="@string/protocol_filter_all" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipTpms"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_tpms" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipPocsag"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_pocsag" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipAdsb"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_adsb" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipUat"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_uat" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipP25"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_p25" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipLoRaWan"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_lorawan" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipMeshtastic"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_meshtastic" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipWmbus"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_wmbus" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipZwave"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_zwave" />

        <com.google.android.material.chip.Chip
          android:id="@+id/chipSidewalk"
          style="@style/Widget.MaterialComponents.Chip.Filter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/protocol_filter_sidewalk" />

      </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="@color/urchin_stroke_soft" />

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1">

      <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/deviceList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="24dp" />

      <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:gravity="center"
        android:padding="20dp"
        android:text="@string/no_devices"
        android:textColor="@color/urchin_on_background"
        android:visibility="gone" />
    </FrameLayout>
  </LinearLayout>

  <ScrollView
    android:id="@+id/filterDrawer"
    android:layout_width="340dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/urchin_surface"
    android:fillViewport="true">

    <LinearLayout
      android:id="@+id/filterDrawerContent"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:paddingStart="16dp"
      android:paddingTop="20dp"
      android:paddingEnd="16dp"
      android:paddingBottom="24dp">

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filters_panel_title"
        android:textColor="@color/urchin_secondary"
        android:textSize="20sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/scanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/scan_inactive"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/permissionHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/urchin_on_background" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/permissionActionButton"
        style="@style/UrchinSecondaryButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/retry_scan" />

      <TextView
        android:id="@+id/hardwareSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/panel_surface_subtle"
        android:padding="14dp"
        android:textColor="@color/urchin_on_surface" />

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/source_label"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <RadioGroup
        android:id="@+id/sourceGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <RadioButton
          android:id="@+id/usbSource"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/usb_source_label"
          android:textColor="@color/urchin_on_surface" />

        <RadioButton
          android:id="@+id/networkSource"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/network_source_label"
          android:textColor="@color/urchin_on_surface" />
      </RadioGroup>

      <LinearLayout
        android:id="@+id/networkConfigGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp">

          <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/networkHostInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/network_host"
            android:inputType="textUri"
            android:textColor="@color/urchin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp">

          <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/networkPortInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/network_port"
            android:inputType="number"
            android:textColor="@color/urchin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
          android:id="@+id/testConnectionButton"
          style="@style/Widget.Material3.Button.OutlinedButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp"
          android:text="@string/test_connection" />
      </LinearLayout>

      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/protocols_label"
        android:textColor="@color/urchin_secondary"
        android:textStyle="bold" />

      <CheckBox
        android:id="@+id/protocolTpms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:checked="true"
        android:text="@string/protocol_tpms"
        android:textColor="@color/urchin_on_surface" />

      <RadioGroup
        android:id="@+id/tpmsFreqGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <RadioButton
          android:id="@+id/freq315"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/frequency_315"
          android:textColor="@color/urchin_on_surface" />

        <RadioButton
          android:id="@+id/freq433"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="16dp"
          android:text="@string/frequency_433"
          android:textColor="@color/urchin_on_surface" />
      </RadioGroup>

      <CheckBox
        android:id="@+id/protocolPocsag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_pocsag"
        android:textColor="@color/urchin_on_surface" />

      <CheckBox
        android:id="@+id/protocolAdsb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_adsb"
        android:textColor="@color/urchin_on_surface" />

      <CheckBox
        android:id="@+id/protocolUat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_uat"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/uatPortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/uatPortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/uat_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <CheckBox
        android:id="@+id/protocolP25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_p25"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/p25PortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/p25PortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/p25_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <TextView
        android:id="@+id/rakHatLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/protocols_rak_hat_label"
        android:textColor="@color/urchin_secondary"
        android:textSize="12sp" />

      <CheckBox
        android:id="@+id/protocolLoRaWan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_lorawan"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/lorawanPortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/lorawanPortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/lorawan_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <CheckBox
        android:id="@+id/protocolMeshtastic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_meshtastic"
        android:textColor="@color/urchin_on_surface" />

      <CheckBox
        android:id="@+id/protocolWmbus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_wmbus"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/wmbusPortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/wmbusPortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/wmbus_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <CheckBox
        android:id="@+id/protocolZwave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_zwave"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/zwavePortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/zwavePortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/zwave_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <CheckBox
        android:id="@+id/protocolSidewalk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/protocol_sidewalk"
        android:textColor="@color/urchin_on_surface" />

      <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/sidewalkPortLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/sidewalkPortInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/sidewalk_network_port"
          android:inputType="number"
          android:textColor="@color/urchin_on_surface" />
      </com.google.android.material.textfield.TextInputLayout>

      <TextView
        android:id="@+id/hoppingWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/panel_surface_subtle"
        android:padding="10dp"
        android:text="@string/hopping_warning"
        android:textColor="@color/urchin_secondary"
        android:textSize="12sp"
        android:visibility="gone" />

      <LinearLayout
        android:id="@+id/usbHardwareGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp">

          <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/gainInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/gain_hint"
            android:inputType="number"
            android:textColor="@color/urchin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>
      </LinearLayout>

      <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/urchin_stroke_soft" />

      <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
          android:id="@+id/filterInput"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/filter_hint"
          android:textColor="@color/urchin_on_surface"
          android:textColorHint="@color/urchin_secondary" />
      </com.google.android.material.textfield.TextInputLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/sort_label"
          android:textColor="@color/urchin_on_background" />

        <Spinner
          android:id="@+id/sortSpinner"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:layout_weight="1" />
      </LinearLayout>

      <CheckBox
        android:id="@+id/liveOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/live_only"
        android:textColor="@color/urchin_on_background" />

      <CheckBox
        android:id="@+id/starredOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/starred_only"
        android:textColor="@color/urchin_on_background" />

      <CheckBox
        android:id="@+id/batteryLowOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/battery_low_only"
        android:textColor="@color/urchin_on_background" />
    </LinearLayout>
  </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
